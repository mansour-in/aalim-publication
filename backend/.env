# ============================================
# LOCAL DEVELOPMENT CONFIG
# ============================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ============================================
# DATABASE - Local MySQL (install MySQL first)
# ============================================
# If you don't have MySQL installed, run:
#   brew install mysql
#   brew services start mysql
#   mysql -u root -e "CREATE DATABASE hadith_fundraiser_local;"
#
# Or use these SQLite-compatible settings for quick testing:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hadith_fundraiser_local
DB_USER=root
DB_PASSWORD=

# ============================================
# RAZORPAY - Test Keys Only
# ============================================
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=local_webhook_secret

# ============================================
# JWT
# ============================================
JWT_SECRET=local-dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_DONOR_EXPIRES_IN=24h

# ============================================
# EMAIL - Optional for local
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Aalim Fundraiser Local <local@example.com>

# ============================================
# CAMPAIGN
# ============================================
FUNDRAISING_GOAL=500000
PRICE_PER_HADITH=500

# ============================================
# SECURITY
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
